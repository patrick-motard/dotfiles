# -*- mode: sh; -*-
# vim: set ft=zsh:
#region Notes

# What are these 'region' and 'endregion' sections?
# 'region' and 'endregion' are used throughout this file to
# provide folding in vscode, so that I can expand/collapse
# whole sections of this file for easier editing.

#endregion Notes

#region Profiling
# Usage: PROFILE_STARTUP=true zsh
if [[ "$PROFILE_STARTUP" == true ]]; then
  zmodload zsh/zprof
fi
#endregion Profiling

#region History
export HISTSIZE=100000 # max events for internal history
export SAVEHIST=100000 # max events in history file
export HISTFILE="${ZDOTDIR}/.zhistory"
# immediately append to history instead of on terminal close
setopt HIST_FIND_NO_DUPS
setopt EXTENDED_HISTORY         # record command start time
setopt INC_APPEND_HISTORY_TIME  # append command to history file immediately after execution
setopt SHARE_HISTORY
bindkey '^R' history-incremental-search-backward
alias history="fc -l 1"         # Ensure all history is shown
alias historyts="fc -f -l 1"    # Show all history, with timestamp
#endregion History

#region Completion
# Optimize compinit: skip compaudit on every startup (saves ~170ms).
# Full compinit (with security audit) only runs once per day.
autoload -Uz compinit
# Glob qualifier (#qN.mh+24) requires extendedglob to work as a pattern
setopt extendedglob
if [[ -n ${ZDOTDIR}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
#endregion Completion

#region SSH
# Reuse existing ssh-agent if available, otherwise start new one
if [ -z "$SSH_AUTH_SOCK" ]; then
  eval "$(ssh-agent -s)" &> /dev/null
fi
[[ -f ~/.ssh/github ]] && ssh-add -q ~/.ssh/github 2>/dev/null
[[ -f ~/.ssh/lahey ]] && ssh-add -q ~/.ssh/lahey 2>/dev/null
#endregion SSH

#region Linux specific
#endregion Linux specific

# Add local bin directories to PATH (only if they exist)
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/.local/bin/ssh-create" ]] && export PATH="$PATH:$HOME/.local/bin/ssh-create"

#region OSX specific
# Lazy-load rbenv (saves ~577ms) - same pattern as nodenv
if [[ -d "$HOME/.rbenv" ]]; then
  export PATH="$HOME/.rbenv/shims:$HOME/.rbenv/bin:$PATH"
{{ if eq .chezmoi.os "darwin" -}}
  # Ruby Neovim setup - ensures neovim can access 'neovim-ruby-host'
  # You can verify with :checkhealth in neovim
  local _rbv=$(cat "$HOME/.ruby-version" 2>/dev/null || cat "$HOME/.rbenv/version" 2>/dev/null)
  [[ -n "$_rbv" ]] && export PATH="$PATH:$HOME/.rbenv/versions/$_rbv/bin"
{{ end -}}

  rbenv() {
    unset -f rbenv
    eval "$(command rbenv init - zsh)"
    rbenv "$@"
  }
fi

# Tmux 256 color support
# https://gpanders.com/blog/the-definitive-guide-to-using-tmux-256color-on-macos/
export PATH="/opt/homebrew/opt/ncurses/bin:$PATH"
export TERMINFO_DIRS=$TERMINFO_DIRS:$HOME/.local/share/terminfo
export TERM=tmux-256color

#endregion OSX specific

{{ if eq .chezmoi.hostname "GVXPDWWKWG" -}}
#region Zendesk-specific configuration
[[ -f ~/.ssh/zendesk-company ]] && ssh-add -qK ~/.ssh/zendesk-company

## BEGIN -- managed by dot-ansible:zendesk -- ##
# export PLUGINS=$plugins
[[ -f ~/.local/bin/zendesk_zshrc.sh ]] && source ~/.local/bin/zendesk_zshrc.sh
## END -- managed by dot-ansible:zendesk -- ##

# for the billing repo
export HUSKY=0

# CICD - lazy-load completion on first use (saves ~160ms)
cicd() {
  unfunction cicd
  source <(command cicd completion zsh)
  cicd "$@"
}

## BEGIN -- managed by workstation, role: aws_cli -- ##
alias awswhoami='aws sts get-caller-identity'
function awscreds {
    aws-work.sh $1
    export AWS_PROFILE=$1
}
## END -- managed by workstation, role: aws_cli -- ##

#endregion Zendesk-specific configuration
{{ end -}}

#region Directories
setopt AUTO_CD           # Auto-change directory without typing cd.
setopt AUTO_PUSHD        # Push dirs to the stack when cd'ing.
setopt EXTENDED_GLOB     # Use extended globbing syntax.
setopt PUSHD_IGNORE_DUPS # Don't push duplicates to the stack.
setopt PUSHD_SILENT      # Do not print the directory stack after pushd or popd.

alias d='dirs -v'
for index ({1..9}) alias "$index"="cd +${index}"; unset index
#endregion Directories

#region Nodenv
# Lazy load nodenv to improve shell startup time
if [[ -d "$HOME/.nodenv" ]]; then
  export PATH="$HOME/.nodenv/shims:$HOME/.nodenv/bin:$PATH"

  # Lazy-load nodenv init (rehash, completions, etc.)
  nodenv() {
    unset -f nodenv
    eval "$(command nodenv init - zsh)"
    nodenv "$@"
  }
fi
#endregion Nodenv

# Load aliases at the end to ensure they aren't clobbered.
source $ZDOTDIR/aliases.zsh

#region Zinit
# zinit plugin manager, installed via ansible (roles/zsh)
source ~/.zinit/bin/zinit.zsh

# vi mode (eager - needed before prompt)
zinit snippet OMZP::vi-mode

# agnoster theme (eager - renders the prompt)
# Requires OMZ git library for parse_git_dirty
setopt promptsubst
zinit snippet OMZL::git.zsh
DEFAULT_USER=$USER
prompt_context() {}
tf_prompt_info() {}
zinit snippet OMZT::agnoster

# Autosuggestions (eager - needed immediately for first command)
zinit light zsh-users/zsh-autosuggestions
bindkey 'lk' autosuggest-accept
bindkey 'lc' autosuggest-clear

# Syntax highlighting (turbo - cosmetic, can load after prompt)
zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting
#endregion Zinit

#region zoxide
# Fast zsh directory switching
# Note: eager init required so cd hook tracks all directory changes
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi
#endregion zoxide

#region fzf
if command -v fzf >/dev/null 2>&1; then
    source <(fzf --zsh)
else
    echo "fzf is not installed. Please install it to use its features."
fi
#endregion fzf

#region Custom Key Bindings

# ## Colemak-DH layout
# # rebind esc for vim mode
# bindkey -M viins 'ts' vi-cmd-mode
# # this is for the zsh-autosuggetions plugin
# bindkey 'nn' autosuggest-accept
# bindkey 'nc' autosuggest-clear
# # bindkey 'ln' autosuggest-toggle

## Qwerty layout.
# rebind esc for vim mode
bindkey -M viins 'fd' vi-cmd-mode

# Sesh - tmux session manager.
# This function allows you to select a tmux session from a list and connect to it
# when not already in a tmux session.
# https://github.com/joshmedeski/sesh
function sesh-sessions() {
  {
    exec </dev/tty
    exec <&1
    local session
    session=$(sesh list -t -c | fzf --height 40% --reverse --border-label ' sesh ' --border --prompt '⚡  ')
    zle reset-prompt > /dev/null 2>&1 || true
    [[ -z "$session" ]] && return
    sesh connect $session
  }
}
zle     -N             sesh-sessions
bindkey -M vicmd '\es' sesh-sessions
bindkey -M viins '\es' sesh-sessions
#endregion Custom Key Bindings

# Print profiling results if enabled
if [[ "$PROFILE_STARTUP" == true ]]; then
  zprof
fi
