# -*- mode: sh; -*-
# vim: set ft=zsh:

# Machine type detection
{{ if eq .chezmoi.hostname "GVXPDWWKWG" -}}
export IS_WORK_MACHINE=1
{{ else -}}
export IS_WORK_MACHINE=0
{{ end -}}

export ZDOTDIR="$HOME/.zsh"
# code_dir="$(which code)"
# export EDITOR="${code_dir}"
# export VISUAL="${code_dir}"
export EDITOR=nvim
export VISUAL=nvim
export PATH="$PATH:$HOME/.local/bin/tools"
export PATH="$PATH:$HOME/code/scripts-private"
export PATH="$PATH:$HOME/code/scripts-private/bin"

# Create ~/.local/bin, used in many places in my dotfiles
[ ! -d ~/.local/bin ] && mkdir -p ~/.local/bin


# export BROWSER=''

{{ if eq .chezmoi.hostname "GVXPDWWKWG" -}}
# Zendesk wiki vault root for zd plugin
export ZD_VAULT_ROOT="${HOME}/code/zendesk/wiki-zendesk"

# Enable Node.js to use system CA certificates (required for Claude Code)
export NODE_USE_SYSTEM_CA=1

[[ -f ~/.zendesk-zshenv ]] && source ~/.zendesk-zshenv
## BEGIN -- managed by dot-ansible:zendesk -- ##
[[ -f ~/.local/bin/zendesk_zshenv.sh ]] && source ~/.local/bin/zendesk_zshenv.sh
## END -- managed by dot-ansible:zendesk -- ##
{{ end -}}

# Needed to ensure Lazygit looks in this dir for it's config.
export XDG_CONFIG_HOME="$HOME/.config"

# https://github.com/sass/sassc-rails/issues/182#issuecomment-2501018835
# export PATH="/opt/homebrew/opt/llvm/bin:$PATH"
# export LDFLAGS="-L/opt/homebrew/opt/llvm/lib"
# export CPPFLAGS="-I/opt/homebrew/opt/llvm/include"
# export CC=clang
# export CXX=clang++
# export SDKROOT="$(xcrun --show-sdk-path)"
#
# For env vars not to be checked in.
[[ -f ~/.local/bin/zshenv.sh ]] && source ~/.local/bin/zshenv.sh || touch ~/.local/bin/zshenv.sh

# Ensure Node's global packages are in the PATH
# Use nodenv shims path directly instead of calling npm (saves ~465ms)
if [[ -d "$HOME/.nodenv" ]]; then
  _node_ver=$(cat "$HOME/.nodenv/version" 2>/dev/null)
  [[ -n "$_node_ver" ]] && export PATH="$PATH:$HOME/.nodenv/versions/$_node_ver"
  unset _node_ver
fi

# Rust
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# Go
export PATH="$PATH:$HOME/go/bin"

{{ if eq .chezmoi.os "darwin" -}}
# Emacs native compilation with Homebrew's libgccjit on macOS
#
# Problem: Emacs 28+ with native-comp fails with "error invoking gcc driver"
# and "library 'emutls_w' not found" when libgccjit can't find GCC libraries.
#
# Solution: Set LIBRARY_PATH to include:
#   1. /opt/homebrew/lib/gcc/current - main gcc libraries including libgccjit
#   2. /opt/homebrew/lib/gcc/current/gcc/<arch>/<version> - contains libemutls_w.a
#
# The arch-specific path is found dynamically (e.g., aarch64-apple-darwin25/15).
# This also needs to be set in ~/.emacs.d.han/early-init.el for GUI launches
# since GUI apps don't inherit shell environment variables.
#
# Only activates if Homebrew's gcc is installed at the expected path.
if [[ -d "/opt/homebrew/lib/gcc/current" ]]; then
  _gcc_lib="/opt/homebrew/lib/gcc/current"
  _gcc_arch=($_gcc_lib/gcc/*apple-darwin*(N[1]))
  if [[ -n "$_gcc_arch" ]]; then
    _gcc_ver=($_gcc_arch/[0-9]*(N[1]))
    export LIBRARY_PATH="${_gcc_lib}${_gcc_ver:+:$_gcc_ver}${LIBRARY_PATH:+:$LIBRARY_PATH}"
  fi
  unset _gcc_lib _gcc_arch _gcc_ver
fi
{{ end -}}
